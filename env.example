# Docker Compose Environment Variables
# Copy this file to .env and update the values

# Path to your AEM quickstart jar (required)
AEM_QUICKSTART=/path/to/cq-quickstart-6.6.0-SNAPSHOT.jar

# Public base URL used for authentication links
# Docker/local: http://localhost:8085
# RDE/Cloud: https://publish-pXXXXX-eYYYYYY.adobeaemcloud.com
PUBLISH_URL=http://localhost:8085

